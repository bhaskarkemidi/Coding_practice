#include <iostream>

class ShallowCopyExample {
private:
    int* data;
    int size;

public:
    // Constructor
    ShallowCopyExample(int size) : size(size) {
        data = new int[size];
        for (int i = 0; i < size; ++i) {
            data[i] = i + 1;
        }
    }

    // Destructor
    ~ShallowCopyExample() {
        delete[] data;
    }

    // Shallow copy constructor
    ShallowCopyExample(const ShallowCopyExample& other) : size(other.size), data(other.data) {}

    void displayData() {
        for (int i = 0; i < size; ++i) {
            std::cout << data[i] << " ";
        }
        std::cout << std::endl;
    }
};

int main() {
    // Create the original object
    ShallowCopyExample originalObj(5);

    // Create a new object using the shallow copy constructor
    ShallowCopyExample shallowCopyObj = originalObj;

    // Display data of both objects
    std::cout << "Original object data: ";
    originalObj.displayData();

    std::cout << "Shallow copy object data: ";
    shallowCopyObj.displayData();

    return 0;
}
